# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/supply_chain_db

# Server Configuration
PORT=3001
NODE_ENV=development

# API Keys
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
MAPBOX_API_KEY=your_mapbox_api_key_here
# OR use OpenRouteService instead
OPENROUTE_API_KEY=your_openrouteservice_api_key_here

# AI Service Configuration
AI_SERVICE_URL=http://localhost:8000

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# WebSocket Configuration
WEBSOCKET_PORT=3001

# Simulation Configuration
SIMULATION_ENABLED=true
SIMULATION_SPEED_MULTIPLIER=1
SIMULATION_UPDATE_INTERVAL_MS=30000

# Logging
LOG_LEVEL=info
